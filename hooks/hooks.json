{
  "description": "Uncle Bob canon enforcement — Cell 8 best-of-breed stack: PostToolUse regex scanner (Tier-1) + UserPromptSubmit grade-card delivery + conditional Stop LLM gate (Tier-2) + SessionStart snapshot + PreCompact summary.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sessionstart-snapshot.mjs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/posttooluse-regex-scan.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/userpromptsubmit-grade-card.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-uncle-bob.mjs\"",
            "timeout": 900
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact-summary.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
